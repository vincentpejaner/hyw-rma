PORT=3001

# Preferred on Railway: add a variable reference to the MySQL service URL.
MYSQL_URL=mysql://root:password@mysql.railway.internal:3306/railway

# Optional Railway split variables.
MYSQLHOST=mysql.railway.internal
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=password
MYSQLDATABASE=railway

# Optional local/fallback variables for non-Railway environments.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=rma_practice
